        <!--Ocho Help View Controller-->
        <scene sceneID="Ic9-7M-3pf">
            <objects>
                <viewController id="PeM-ew-ehD" customClass="OchoHelpViewController" sceneMemberID="viewController">
                    <view key="view" contentMode="scaleToFill" id="LKZ-0Q-Erc">
                        <rect key="frame" x="0.0" y="0.0" width="320" height="480"/>
                        <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMaxY="YES"/>
                        <subviews>
                            <imageView userInteractionEnabled="NO" contentMode="scaleAspectFit" image="AdamZapplCropped.png" id="kfh-Ev-ckM">
                                <rect key="frame" x="100" y="400" width="120" height="60"/>
                            </imageView>
                            <button opaque="NO" contentMode="scaleToFill" contentHorizontalAlignment="center" contentVerticalAlignment="center" buttonType="roundedRect" lineBreakMode="middleTruncation" id="UwN-u1-Sa8">
                                <rect key="frame" x="106" y="356" width="108" height="44"/>
                                <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMinY="YES"/>
                                <fontDescription key="fontDescription" type="boldSystem" pointSize="14"/>
                                <state key="normal" title="RETURN" backgroundImage="silverRectButton.png">
                                    <color key="titleColor" white="1" alpha="1" colorSpace="calibratedWhite"/>
                                    <color key="titleShadowColor" white="0.5" alpha="1" colorSpace="calibratedWhite"/>
                                </state>
                                <state key="highlighted">
                                    <color key="titleColor" white="1" alpha="1" colorSpace="calibratedWhite"/>
                                </state>
                                <connections>
                                    <action selector="dismissHelp:" destination="PeM-ew-ehD" eventType="touchUpInside" id="wKJ-OP-TPw"/>
                                </connections>
                            </button>
                            <textView clipsSubviews="YES" multipleTouchEnabled="YES" contentMode="scaleToFill" indicatorStyle="black" editable="NO" usesAttributedText="YES" id="ZlZ-uk-Akp">
                                <rect key="frame" x="20" y="20" width="280" height="328"/>
                                <autoresizingMask key="autoresizingMask" flexibleMaxX="YES" flexibleMaxY="YES"/>
                                <color key="backgroundColor" white="0.0" alpha="1" colorSpace="calibratedWhite"/>
                                <attributedString key="attributedText">
                                    <fragment>
                                        <string key="content">The object of Ocho is simple: to score as many points as you can. This is done by tossing 8 coins numbered 1 through 8 into 8 numbered cups. Start by tapping the big coin that says "Toss." Each coin lands in a cup. If a coin lands in the matching cup, it lights up. The big coin shows the total value of all matching coins. You can either keep that total as your score for this turn by tapping the big coin or toss the non-matching coins again by giving back one match. You give back a match and toss again by tapping one of the matching coins. Obviously it is best to give back your lowest matching coin. The turn continues until you either keep the score or run out of matches to give back. Your score for that turn is recorded in the next score box and added to your total score. You start the next turn by tapping the big coin again. You get 8 turns to complete a round and here is the important part: </string>
                                        <attributes>
                                            <color key="NSBackgroundColor" white="0.0" alpha="1" colorSpace="calibratedWhite"/>
                                            <color key="NSColor" red="0.96862745100000003" green="0.96862745100000003" blue="0.96862745100000003" alpha="1" colorSpace="calibratedRGB"/>
                                            <font key="NSFont" size="18" name="Optima-Regular"/>
                                            <font key="NSOriginalFont" size="12" name="Helvetica-Light"/>
                                            <paragraphStyle key="NSParagraphStyle" alignment="left" lineBreakMode="wordWrapping" baseWritingDirection="natural"/>
                                        </attributes>
                                    </fragment>
                                    <fragment>
                                        <string key="content">if your total for the round is at least 88 then you get to continue with another round. If it is less than 88 then the game is over</string>
                                        <attributes>
                                            <color key="NSBackgroundColor" white="0.0" alpha="1" colorSpace="calibratedWhite"/>
                                            <color key="NSColor" red="0.96862745100000003" green="0.96862745100000003" blue="0.96862745100000003" alpha="1" colorSpace="calibratedRGB"/>
                                            <font key="NSFont" size="18" name="Optima-ExtraBlack"/>
                                            <font key="NSOriginalFont" size="14" name="Arial-BoldMT"/>
                                            <paragraphStyle key="NSParagraphStyle" alignment="left" lineBreakMode="wordWrapping" baseWritingDirection="natural"/>
                                        </attributes>
                                    </fragment>
                                    <fragment content=". ">
                                        <attributes>
                                            <color key="NSBackgroundColor" white="0.0" alpha="1" colorSpace="calibratedWhite"/>
                                            <color key="NSColor" red="0.96862745100000003" green="0.96862745100000003" blue="0.96862745100000003" alpha="1" colorSpace="calibratedRGB"/>
                                            <font key="NSFont" size="18" name="Optima-Regular"/>
                                            <font key="NSOriginalFont" size="14" name="Arial-BoldMT"/>
                                            <paragraphStyle key="NSParagraphStyle" alignment="left" lineBreakMode="wordWrapping" baseWritingDirection="natural"/>
                                        </attributes>
                                    </fragment>
                                    <fragment content="The box above the big coin shows your round total on the left in ">
                                        <attributes>
                                            <color key="NSBackgroundColor" white="0.0" alpha="1" colorSpace="calibratedWhite"/>
                                            <color key="NSColor" red="0.96862745100000003" green="0.96862745100000003" blue="0.96862745100000003" alpha="1" colorSpace="calibratedRGB"/>
                                            <font key="NSFont" size="18" name="Optima-Regular"/>
                                            <font key="NSOriginalFont" size="12" name="Helvetica-Light"/>
                                            <paragraphStyle key="NSParagraphStyle" alignment="left" lineBreakMode="wordWrapping" baseWritingDirection="natural"/>
                                        </attributes>
                                    </fragment>
                                    <fragment content="white">
                                        <attributes>
                                            <color key="NSBackgroundColor" white="0.0" alpha="1" colorSpace="calibratedWhite"/>
                                            <color key="NSColor" red="0.96862745100000003" green="0.96862745100000003" blue="0.96862745100000003" alpha="1" colorSpace="calibratedRGB"/>
                                            <font key="NSFont" size="18" name="Optima-ExtraBlack"/>
                                            <font key="NSOriginalFont" size="12" name="Helvetica-Light"/>
                                            <paragraphStyle key="NSParagraphStyle" alignment="left" lineBreakMode="wordWrapping" baseWritingDirection="natural"/>
                                        </attributes>
                                    </fragment>
                                    <fragment content=" and the number of points you need to get to 88 on the right in ">
                                        <attributes>
                                            <color key="NSBackgroundColor" white="0.0" alpha="1" colorSpace="calibratedWhite"/>
                                            <color key="NSColor" red="0.96862745100000003" green="0.96862745100000003" blue="0.96862745100000003" alpha="1" colorSpace="calibratedRGB"/>
                                            <font key="NSFont" size="18" name="Optima-Regular"/>
                                            <font key="NSOriginalFont" size="12" name="Helvetica-Light"/>
                                            <paragraphStyle key="NSParagraphStyle" alignment="left" lineBreakMode="wordWrapping" baseWritingDirection="natural"/>
                                        </attributes>
                                    </fragment>
                                    <fragment content="red">
                                        <attributes>
                                            <color key="NSBackgroundColor" white="0.0" alpha="1" colorSpace="calibratedWhite"/>
                                            <color key="NSColor" red="0.67805325255102034" green="0.0" blue="0.0073575601403617664" alpha="1" colorSpace="calibratedRGB"/>
                                            <font key="NSFont" size="18" name="Optima-ExtraBlack"/>
                                            <font key="NSOriginalFont" size="18" name="Optima-ExtraBlack"/>
                                            <paragraphStyle key="NSParagraphStyle" alignment="left" lineBreakMode="wordWrapping" baseWritingDirection="natural"/>
                                        </attributes>
                                    </fragment>
                                    <fragment>
                                        <string key="content">.
That's it. Play as many rounds as you can and get the highest total score you can. But beware, it's hard to stop playing!</string>
                                        <attributes>
                                            <color key="NSBackgroundColor" white="0.0" alpha="1" colorSpace="calibratedWhite"/>
                                            <color key="NSColor" red="0.96862745100000003" green="0.96862745100000003" blue="0.96862745100000003" alpha="1" colorSpace="calibratedRGB"/>
                                            <font key="NSFont" size="18" name="Optima-Regular"/>
                                            <font key="NSOriginalFont" size="12" name="Helvetica-Light"/>
                                            <paragraphStyle key="NSParagraphStyle" alignment="left" lineBreakMode="wordWrapping" baseWritingDirection="natural"/>
                                        </attributes>
                                    </fragment>
                                </attributedString>
                                <textInputTraits key="textInputTraits" autocapitalizationType="sentences"/>
                            </textView>
                        </subviews>
                        <color key="backgroundColor" white="0.0" alpha="1" colorSpace="calibratedWhite"/>
                    </view>
                    <nil key="simulatedStatusBarMetrics"/>
                </viewController>
                <placeholder placeholderIdentifier="IBFirstResponder" id="sr6-48-tet" userLabel="First Responder" sceneMemberID="firstResponder"/>
            </objects>
            <point key="canvasLocation" x="812" y="-293"/>
        </scene>
